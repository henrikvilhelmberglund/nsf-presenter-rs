{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Build nsf-player (release)",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--release", "-p", "nsf-player"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": ["$rustc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    },
    {
      "label": "Run nsf-player",
      "type": "process",
      "command": "${workspaceFolder}/target/release/nsf-player.exe",
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "dependsOn": ["Build nsf-player (release)"],
      "problemMatcher": [],
      "presentation": {
        "reveal": "silent",
        "panel": "dedicated"
      }
    },
    {
      "label": "Build nsf-presenter (release)",
      "type": "shell",
      "command": "cargo",
      "args": ["build", "--release", "-p", "nsf-presenter"],
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "group": "build",
      "problemMatcher": ["$rustc"],
      "presentation": {
        "reveal": "always",
        "panel": "shared",
        "clear": true
      }
    }
  ]
}
